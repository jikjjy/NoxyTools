<Window x:Class="NoxyTools.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NoxyTools.Wpf.ViewModels"
        xmlns:views="clr-namespace:NoxyTools.Wpf.Views"
        xmlns:conv="clr-namespace:NoxyTools.Wpf.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="NoxyTools"
        Icon="/free-icon-video-game-3571528.ico"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Background="{StaticResource PanelBackgroundBrush}">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverterInv" Invert="True"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ViewModel → View DataTemplate 매핑 -->
        <DataTemplate DataType="{x:Type vm:MakeValidReportViewModel}">
            <views:MakeValidReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NoxypediaSearchViewModel}">
            <views:NoxypediaSearchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemSimulatorViewModel}">
            <views:ItemSimulatorView/>
        </DataTemplate>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <DockPanel>

        <!-- ============================================================ -->
        <!-- 상단 메뉴 바 (탭 전환 RadioButton)                             -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource MenuBarBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 윈도우 컨트롤 버튼: 최소화 / 최대화 / 닫기 (최우측) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="─"
                            ToolTip="최소화"
                            Click="MinimizeButton_Click"/>
                    <Button x:Name="MaxRestoreButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Content="□"
                            ToolTip="최대화"
                            Click="MaxRestoreButton_Click"/>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="✕"
                            ToolTip="닫기"
                            Click="CloseButton_Click"/>
                </StackPanel>

                <!-- 앱 아이콘/타이틀 -->
                <TextBlock DockPanel.Dock="Left"
                           Text="◈ NoxyTools"
                           Foreground="{StaticResource AccentTextBrush}"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="12,0"/>

                <!-- 버전 표시 (우측 정렬) -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding AppVersion}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           WindowChrome.IsHitTestVisibleInChrome="True"/>

                <!-- 설정 백업 / 복구 / 업데이트 버튼 (우측 정렬) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            Margin="0,0,4,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="⬆ 백업"
                            Command="{Binding BackupSettingsCommand}"
                            ToolTip="설정을 파일로 백업합니다"
                            FontSize="11"
                            Margin="0,0,3,0"/>
                    <Button Content="⬇ 복구"
                            Command="{Binding RestoreSettingsCommand}"
                            ToolTip="파일에서 설정을 복구합니다"
                            FontSize="11"
                            Margin="0,0,3,0"/>
                    <Button Content="🔔 업데이트"
                            Command="{Binding CheckForUpdateManualCommand}"
                            ToolTip="최신 버전을 확인합니다"
                            FontSize="11"/>
                </StackPanel>

                <!-- 탭 버튼 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <RadioButton Content="아이템 인증 도우미"
                                 Style="{StaticResource TabRadioButtonStyle}"
                                 IsChecked="{Binding IsMakeValidReportSelected}"
                                 Command="{Binding SelectMakeValidReportCommand}"/>
                    <RadioButton Content="아이템 검색"
                                 Style="{StaticResource TabRadioButtonStyle}"
                                 IsChecked="{Binding IsNoxypediaSearchSelected}"
                                 Command="{Binding SelectNoxypediaSearchCommand}"/>
                    <RadioButton Content="아이템 시뮬레이터"
                                 Style="{StaticResource TabRadioButtonStyle}"
                                 IsChecked="{Binding IsItemSimulatorSelected}"
                                 Command="{Binding SelectItemSimulatorCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- 하단 상태 바                                                   -->
        <!-- ============================================================ -->
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <!-- 로딩 중 점등 표시 -->
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,6,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusText}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================================================ -->
        <!-- 중앙 콘텐츠 영역 (ViewModel → View DataTemplate 자동 매핑)       -->
        <!-- ============================================================ -->
        <Grid Background="{StaticResource SurfaceBackgroundBrush}">
            <!-- ContentControl: DataTemplate으로 ViewModel → View 자동 연결 -->
            <ContentControl Content="{Binding Navigation.CurrentView}"/>
        </Grid>

    </DockPanel>
</Window>
