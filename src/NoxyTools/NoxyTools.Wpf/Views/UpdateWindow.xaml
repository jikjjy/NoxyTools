<Window x:Class="NoxyTools.Wpf.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NoxyTools.Wpf.ViewModels"
    xmlns:conv="clr-namespace:NoxyTools.Wpf.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:UpdateViewModel, IsDesignTimeCreatable=False}"
        Title="NoxyTools 업데이트"
        Width="480" Height="380"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource PanelBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 헤더 -->
            <RowDefinition Height="Auto"/>   <!-- 버전 정보 -->
            <RowDefinition Height="*"/>      <!-- 릴리즈 노트 -->
            <RowDefinition Height="Auto"/>   <!-- 진행 바 -->
            <RowDefinition Height="Auto"/>   <!-- 상태 메시지 -->
            <RowDefinition Height="Auto"/>   <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🔄"
                       FontSize="22"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBlock Text="새 버전이 있습니다"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentTextBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── 버전 정보 ── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="현재 버전: "
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentVersion}"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2"
                       Text="  →  "
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="3"
                       Text="최신 버전: "
                       Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="4"
                       Text="{Binding LatestVersion}"
                       Foreground="{StaticResource AccentTextBrush}"
                       FontWeight="Bold"/>
        </Grid>

        <!-- ── 릴리즈 노트 ── -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <TextBlock Text="{Binding ReleaseNotes}"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           LineHeight="18"/>
            </ScrollViewer>
        </Border>

        <!-- ── 다운로드 진행 바 ── -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <ProgressBar Value="{Binding DownloadProgress}"
                         Minimum="0" Maximum="100"
                         Height="8">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>

        <!-- ── 상태 메시지 ── -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,14"/>

        <!-- ── 버튼 영역 ── -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 릴리즈 페이지 링크 -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center">
                <Hyperlink Click="Hyperlink_Click"
                           Foreground="{StaticResource AccentBrush}">
                    GitHub에서 보기
                </Hyperlink>
            </TextBlock>

            <!-- 취소 버튼 (다운로드 중에만 표시) -->
            <Button Grid.Column="1"
                    Content="취소"
                    Width="70"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsBusy,
                        Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- 나중에 버튼 -->
            <Button Grid.Column="3"
                    Content="나중에"
                    Width="70"
                    Click="BtnLater_Click"/>

            <!-- 업데이트 버튼 -->
            <Button Grid.Column="5"
                    Content="지금 업데이트"
                    Width="100"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Command="{Binding DownloadUpdateCommand}"/>
        </Grid>
    </Grid>
</Window>
