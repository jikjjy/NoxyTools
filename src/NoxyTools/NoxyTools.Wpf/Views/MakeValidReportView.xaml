<UserControl x:Class="NoxyTools.Wpf.Views.MakeValidReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NoxyTools.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MakeValidReportViewModel, IsDesignTimeCreatable=False}">

    <Grid Background="{StaticResource SurfaceBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="240"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- ── 좌측 설정 패널 ────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource MenuBarBackgroundBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,10,12,10">

                    <!-- 프리셋 선택 -->
                    <TextBlock Text="데이터 슬롯" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DataNames}"
                              SelectedIndex="{Binding SelectedDataIndex}"
                              Margin="0,0,0,8"/>

                    <!-- 슬롯 이름 -->
                    <TextBlock Text="슬롯 이름" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DataName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- 캐릭터 정보 -->
                    <TextBlock Text="아이디" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <TextBlock Text="플레이 버전" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PlayVersion, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <TextBlock Text="클래스" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <TextBlock Text="서버" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- 세이브 경로 -->
                    <TextBlock Text="세이브 파일 경로" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Content="..."
                                Width="28"
                                Margin="4,0,0,0"
                                Command="{Binding ChangeSavePathCommand}"
                                Style="{StaticResource SpeedButtonStyle}"/>
                        <TextBox Text="{Binding SavePath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 ToolTip="{Binding SavePath}"/>
                    </DockPanel>

                    <!-- 옵션 -->
                    <CheckBox Content="스탯 변화량 포함"
                              IsChecked="{Binding UseStateStatisticsExport}"
                              Margin="0,0,0,4"/>
                    <CheckBox Content="세이브 코드 포함"
                              IsChecked="{Binding UseAddInfoSaveCode}"
                              Margin="0,0,0,4"/>
                    <CheckBox Content="모든 아이템 목록 포함"
                              IsChecked="{Binding UseAddInfoAllItems}"
                              Margin="0,0,0,12"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- 정렬 방식 -->
                    <TextBlock Text="아이템 정렬" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,6"/>
                    <RadioButton Content="등급순 정렬"
                                 IsChecked="{Binding OrderByGrade}"
                                 GroupName="ItemOrder"
                                 Margin="0,0,0,4"/>
                    <RadioButton Content="이름순 정렬"
                                 IsChecked="{Binding OrderByName}"
                                 GroupName="ItemOrder"
                                 Margin="0,0,0,12"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- 마지막 업데이트 -->
                    <TextBlock Text="마지막 갱신" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastRefreshText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12"
                               Margin="0,0,0,12"/>

                    <!-- 버튼 행 -->
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,6">
                        <Button Content="새로고침"
                                Command="{Binding RefreshCommand}"
                                Margin="0,0,2,0"
                                Style="{StaticResource FlatButtonStyle}"/>
                        <Button Content="저장"
                                Command="{Binding SaveCommand}"
                                Margin="2,0,0,0"
                                Style="{StaticResource FlatButtonStyle}"/>
                    </UniformGrid>
                    <UniformGrid Rows="1" Columns="2">
                        <Button Content="클립보드 복사"
                                Command="{Binding CopyCommand}"
                                Margin="0,0,2,0"
                                Style="{StaticResource FlatButtonStyle}"/>
                        <Button Content="데이터 초기화"
                                Command="{Binding ResetDataCommand}"
                                Margin="2,0,0,0"
                                Style="{StaticResource FlatButtonStyle}"/>
                    </UniformGrid>
                    <Button Content="누락 아이템 수정..."
                            Command="{Binding EditRootItemCommand}"
                            Style="{StaticResource FlatButtonStyle}"
                            ToolTip="Noxypedia에서 획득 아이템 목록을 직접 추가/제거합니다."/>

                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontSize="11">
                        <Hyperlink NavigateUri="https://cafe.naver.com/noxy"
                                   RequestNavigate="CafeHyperlink_RequestNavigate"
                                   Foreground="{StaticResource AccentBrush}">
                            ⇒ 카페 바로가기 (cafe.naver.com/noxy)
                        </Hyperlink>
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── 구분선 ────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ── 우측 미리보기 ─────────────────────────────── -->
        <Border Grid.Column="2" Background="#1E1E1E">
            <RichTextBox x:Name="PreviewRichTextBox"
                         IsReadOnly="True"
                         Background="#1E1E1E"
                         Foreground="#E0E0E0"
                         FontFamily="맑은 고딕, Malgun Gothic"
                         FontSize="12"
                         Padding="8"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto">
                <FlowDocument/>
            </RichTextBox>
        </Border>

    </Grid>
</UserControl>

