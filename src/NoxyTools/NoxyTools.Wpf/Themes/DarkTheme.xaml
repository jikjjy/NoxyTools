<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================================= -->
    <!--  배경 색상                                                  -->
    <!-- ========================================================= -->
    <!-- 가장 어두운 배경 (메인 윈도우) RGB(30,30,30) -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"       Color="#FF1E1E1E"/>
    <!-- 패널/그룹 배경 RGB(45,45,48) -->
    <SolidColorBrush x:Key="PanelBackgroundBrush"        Color="#FF2D2D30"/>
    <!-- 컨트롤 배경 (탭, 트리뷰 등) RGB(37,37,38) -->
    <SolidColorBrush x:Key="SurfaceBackgroundBrush"      Color="#FF252526"/>
    <!-- 입력 컨트롤 배경 (TextBox, ComboBox 등) RGB(63,63,70) -->
    <SolidColorBrush x:Key="ControlBackgroundBrush"      Color="#FF3F3F46"/>
    <!-- 입력 컨트롤 강조 배경 -->
    <SolidColorBrush x:Key="InputBackgroundBrush"        Color="#FF333337"/>
    <!-- 호버 배경 -->
    <SolidColorBrush x:Key="HoverBackgroundBrush"        Color="#FF3E3E42"/>
    <!-- 선택된 행 배경 -->
    <SolidColorBrush x:Key="SelectionBackgroundBrush"    Color="#FF264F78"/>
    <!-- 비활성 선택 배경 -->
    <SolidColorBrush x:Key="InactiveSelectionBrush"      Color="#FF3F3F46"/>

    <!-- ========================================================= -->
    <!--  전경 색상                                                  -->
    <!-- ========================================================= -->
    <SolidColorBrush x:Key="PrimaryTextBrush"            Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"          Color="#FF999999"/>
    <SolidColorBrush x:Key="DisabledTextBrush"           Color="#FF656565"/>
    <SolidColorBrush x:Key="AccentTextBrush"             Color="#FF4EC9B0"/>

    <!-- ========================================================= -->
    <!--  강조 색상                                                  -->
    <!-- ========================================================= -->
    <SolidColorBrush x:Key="AccentBrush"                 Color="#FF007ACC"/>
    <SolidColorBrush x:Key="AccentHoverBrush"            Color="#FF1C97EA"/>
    <SolidColorBrush x:Key="AccentPressedBrush"          Color="#FF005A9E"/>

    <!-- ========================================================= -->
    <!--  테두리 색상                                                -->
    <!-- ========================================================= -->
    <SolidColorBrush x:Key="BorderBrush"                 Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="ActiveBorderBrush"           Color="#FF007ACC"/>
    <SolidColorBrush x:Key="FocusBorderBrush"            Color="#FF007ACC"/>

    <!-- ========================================================= -->
    <!--  상태바 / 특수 영역                                         -->
    <!-- ========================================================= -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush"    Color="#FF007ACC"/>
    <SolidColorBrush x:Key="StatusBarTextBrush"          Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="MenuBarBackgroundBrush"      Color="#FF2D2D30"/>

    <!-- ========================================================= -->
    <!--  아이템 등급 색상                                           -->
    <!-- ========================================================= -->
    <!-- 보조 / 기본 -->
    <SolidColorBrush x:Key="GradeDefaultBrush"           Color="#FFB0B0B0"/>
    <!-- 오메가 -->
    <SolidColorBrush x:Key="GradeOmegaBrush"             Color="#FFFF0000"/>
    <!-- 렐릭 -->
    <SolidColorBrush x:Key="GradeRelicBrush"             Color="#FFFFCC00"/>
    <!-- 차원 -->
    <SolidColorBrush x:Key="GradeDimensionBrush"         Color="#FF0080FF"/>
    <!-- 포가튼 -->
    <SolidColorBrush x:Key="GradeForgottenBrush"         Color="#FF7777AA"/>
    <!-- 상위 차원 -->
    <SolidColorBrush x:Key="GradeHighDimensionBrush"     Color="#FF5AF5B4"/>
    <!-- 언노운 -->
    <SolidColorBrush x:Key="GradeUnknownBrush"           Color="#FFB94652"/>
    <!-- 라브리 -->
    <SolidColorBrush x:Key="GradeLabriBrush"             Color="#FFFF8080"/>
    <!-- 누메논 -->
    <SolidColorBrush x:Key="GradeNumenonBrush"           Color="#FF96E0E9"/>
    <!-- 프렉탈 레어 -->
    <SolidColorBrush x:Key="GradeFractalRareBrush"       Color="#FFFA69C7"/>
    <!-- 프렉탈 에픽 -->
    <SolidColorBrush x:Key="GradeFractalEpicBrush"       Color="#FFB976EF"/>
    <!-- 프렉탈 렐릭 -->
    <SolidColorBrush x:Key="GradeFractalRelicBrush"      Color="#FFFFFFA4"/>
    <!-- 베니타테 -->
    <SolidColorBrush x:Key="GradeVenitateBrush"          Color="#FF716D60"/>
    <!-- 스텔라 -->
    <SolidColorBrush x:Key="GradeStellaBrush"            Color="#FFD2D200"/>
    <!-- 상위 에픽 -->
    <SolidColorBrush x:Key="GradeHighEpicBrush"          Color="#FFFED169"/>

    <!-- ========================================================= -->
    <!--  공통 치수                                                  -->
    <!-- ========================================================= -->
    <CornerRadius x:Key="ControlCornerRadius">3</CornerRadius>
    <Thickness x:Key="ControlPadding">6,4,6,4</Thickness>
    <Thickness x:Key="WindowPadding">8</Thickness>

</ResourceDictionary>
