<UserControl x:Class="NoxyTools.Wpf.Controls.SearchItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:NoxyTools.Wpf.ViewModels"
             xmlns:conv="clr-namespace:NoxyTools.Wpf.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SearchItemViewModel}"
             d:DesignHeight="500" d:DesignWidth="300">

    <UserControl.Resources>
        <conv:GradeToColorConverter x:Key="GradeToColorConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityInv" Invert="True"/>

        <!-- 등급 색상 적용 DataGridRow 스타일 (선택 시 흰색으로 오버라이드) -->
        <Style x:Key="GradeRowStyle" TargetType="DataGridRow"
               BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Foreground"
                    Value="{Binding Grade, Converter={StaticResource GradeToColorConverter}}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 텍스트 필터 바 -->
            <RowDefinition Height="Auto"/>
            <!-- 고급 필터 패널 (선택적 표시) -->
            <RowDefinition Height="Auto"/>
            <!-- 아이템 목록 DataGrid -->
            <RowDefinition Height="*"/>
            <!-- 네비게이션 버튼 바 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!--  Row 0: 텍스트 필터 바                                  -->
        <!-- ===================================================== -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 검색 TextBox + Placeholder 오버레이 -->
                <Grid Grid.Column="0">
                    <TextBox x:Name="FilterTextBox"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="FilterTextBox_TextChanged"
                             VerticalContentAlignment="Center"/>
                    <!-- Placeholder: FilterText가 비어있을 때만 표시 -->
                    <TextBlock Text="아이템 검색..."
                               Foreground="{StaticResource DisabledTextBrush}"
                               Margin="6,0" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- ✕ 지우기 버튼 -->
                <Button Grid.Column="1"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource SpeedButtonStyle}"
                        ToolTip="필터 초기화"
                        Width="22" Height="22"
                        Margin="2,0,0,0">
                    <TextBlock Text="✕" FontSize="10"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </Button>

                <!-- ▼/▲ 고급 필터 토글 버튼 (CanFilterExtension=true 일 때만 표시) -->
                <Button Grid.Column="2"
                        Command="{Binding ToggleFilterPanelCommand}"
                        Style="{StaticResource SpeedButtonStyle}"
                        ToolTip="고급 필터"
                        Width="22" Height="22"
                        Margin="2,0,0,0"
                        Visibility="{Binding CanFilterExtension, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock FontSize="10"
                               Foreground="{StaticResource SecondaryTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="▼"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterPanelExpanded}" Value="True">
                                        <Setter Property="Text" Value="▲"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!-- ===================================================== -->
        <!--  Row 1: 고급 필터 패널                                  -->
        <!-- ===================================================== -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding CanFilterExtension}" Value="True"/>
                                <Condition Binding="{Binding IsFilterPanelExpanded}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 등급 필터 -->
                <CheckBox Grid.Row="0" Grid.Column="0"
                          IsChecked="{Binding IsGradeFilterEnabled}"
                          Content="등급"
                          VerticalAlignment="Center"
                          Margin="0,2,6,2"
                          MinWidth="56"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding GradeNames}"
                          SelectedItem="{Binding FilterGrade}"
                          IsEnabled="{Binding IsGradeFilterEnabled}"
                          Margin="0,2,0,2"
                          Height="22"/>

                <!-- 부위 필터 -->
                <CheckBox Grid.Row="1" Grid.Column="0"
                          IsChecked="{Binding IsPartFilterEnabled}"
                          Content="부위"
                          VerticalAlignment="Center"
                          Margin="0,2,6,2"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding PartNames}"
                          SelectedItem="{Binding FilterPart}"
                          IsEnabled="{Binding IsPartFilterEnabled}"
                          Margin="0,2,0,2"
                          Height="22"/>

                <!-- 직업 필터 -->
                <CheckBox Grid.Row="2" Grid.Column="0"
                          IsChecked="{Binding IsClassFilterEnabled}"
                          Content="직업"
                          VerticalAlignment="Center"
                          Margin="0,2,6,2"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          ItemsSource="{Binding ClassNames}"
                          SelectedItem="{Binding FilterClass}"
                          IsEnabled="{Binding IsClassFilterEnabled}"
                          Margin="0,2,0,2"
                          Height="22"/>

                <!-- 유니크옵션 필터 -->
                <CheckBox Grid.Row="3" Grid.Column="0"
                          IsChecked="{Binding IsUniqueOptionFilterEnabled}"
                          Content="유니크옵션"
                          VerticalAlignment="Center"
                          Margin="0,2,6,2"/>
                <ComboBox Grid.Row="3" Grid.Column="1"
                          ItemsSource="{Binding UniqueOptionNames}"
                          SelectedItem="{Binding FilterUniqueOption}"
                          IsEnabled="{Binding IsUniqueOptionFilterEnabled}"
                          Margin="0,2,0,2"
                          Height="22"/>
            </Grid>
        </Border>

        <!-- ===================================================== -->
        <!--  Row 2: 아이템 목록 DataGrid                            -->
        <!-- ===================================================== -->
        <DataGrid Grid.Row="2"
                  x:Name="ItemDataGrid"
                  ItemsSource="{Binding ItemsView}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  RowStyle="{StaticResource GradeRowStyle}"
                  SelectionChanged="ItemDataGrid_SelectionChanged"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="등급"
                                    Binding="{Binding Grade.Name}"
                                    Width="Auto"
                                    MinWidth="50"/>
                <DataGridTextColumn Header="부위"
                                    Binding="{Binding Part}"
                                    Width="Auto"
                                    MinWidth="50"/>
                <DataGridTextColumn Header="이름"
                                    Binding="{Binding Name}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ===================================================== -->
        <!--  Row 3: 네비게이션 버튼 바                              -->
        <!-- ===================================================== -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                <!-- ◀ 이전 아이템 -->
                <Button Command="{Binding NavigatePreviousCommand}"
                        Style="{StaticResource SpeedButtonStyle}"
                        ToolTip="이전 아이템 (Alt+Left)">
                    <TextBlock Text="◀" FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </Button>

                <!-- ▶ 다음 아이템 -->
                <Button Command="{Binding NavigateNextCommand}"
                        Style="{StaticResource SpeedButtonStyle}"
                        ToolTip="다음 아이템 (Alt+Right)">
                    <TextBlock Text="▶" FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </Button>

                <Separator Width="1" Height="20" Margin="4,0"/>

                <!-- ★ 즐겨찾기 토글 -->
                <Button Command="{Binding ToggleFavoriteCommand}"
                        Style="{StaticResource SpeedButtonStyle}"
                        ToolTip="즐겨찾기 토글">
                    <TextBlock FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="☆"/>
                                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedItemFavorite}" Value="True">
                                        <Setter Property="Text" Value="★"/>
                                        <Setter Property="Foreground" Value="#FFFFE066"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Separator Width="1" Height="20" Margin="4,0"/>

                <!-- ☰ 전체 보기 (IsFavoriteOnlyView=false일 때 활성) -->
                <ToggleButton IsChecked="{Binding IsShowingAll, Mode=TwoWay}"
                              Style="{StaticResource SpeedToggleButtonStyle}"
                              ToolTip="모든 아이템 표시">
                    <TextBlock Text="☰" FontSize="13"/>
                </ToggleButton>

                <!-- ⭐ 즐겨찾기만 보기 -->
                <ToggleButton IsChecked="{Binding IsFavoriteOnlyView, Mode=TwoWay}"
                              Style="{StaticResource SpeedToggleButtonStyle}"
                              ToolTip="즐겨찾기 아이템만 표시">
                    <TextBlock Text="⭐" FontSize="13"/>
                </ToggleButton>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
